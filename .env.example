# =============================================================================
# .env.example — Copy to .env and fill in real values
# NEVER commit .env to git
# =============================================================================

# Trading mode: paper (safe simulation) | live (real Zerodha orders)
TRADING_MODE=paper

# Zerodha Kite API (only needed for live mode)
KITE_API_KEY=
KITE_API_SECRET=

# Telegram Bot alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ollama (optional — local LLM for sentiment analysis)
# Defaults to http://localhost:11434 if not set
# OLLAMA_BASE_URL=http://localhost:11434
